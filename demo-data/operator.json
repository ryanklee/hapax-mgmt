{
  "version": 1,
  "operator": {
    "name": "Demo Operator",
    "role": "Engineering Manager",
    "context": "Managing 3 teams (Platform, Product, Data) totaling 7 engineers. Focus areas: technical leadership development, team health, and cross-team coordination."
  },
  "axioms": {
    "single_operator": true,
    "decision_support": true,
    "management_safety": true
  },
  "constraints": {
    "communication": [
      "Lead with outcomes, not activity",
      "Written follow-up for all feedback conversations",
      "Weekly status updates to skip-level"
    ],
    "management": [
      "Never skip 1:1s two weeks in a row",
      "Coaching hypotheses must have measurable outcomes",
      "Career conversations at least quarterly"
    ]
  },
  "patterns": {
    "decision_making": [
      "Bias toward action with reversible decisions",
      "Escalate irreversible decisions early",
      "Document trade-offs, not just conclusions"
    ],
    "workflow": [
      "Morning: review dashboard, address critical nudges",
      "Before 1:1s: review prep docs, note coaching experiments",
      "Friday: weekly review of team health and open loops"
    ],
    "communication": [
      "Headline-first for stakeholders",
      "Specific examples in all feedback",
      "Ask before telling in coaching conversations"
    ]
  },
  "goals": {
