[Unit]
Description=Hapax Officium Logos API
After=network.target

[Service]
Type=simple
ExecStart=/home/hapax/.local/bin/uv --directory /home/hapax/projects/hapax-officium run python -m logos.api --host 0.0.0.0 --port 8050
Environment=PATH=/home/hapax/.local/bin:/usr/local/bin:/usr/bin:/bin
Environment=HOME=/home/hapax
Restart=on-failure
RestartSec=5
MemoryMax=512M

[Install]
WantedBy=default.target
